# PHANTOM Production Config
# IMPORTANT: Change ALL passwords and keys before deploying!

# Database
POSTGRES_USER=phantom
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=phantom
DATABASE_URL=postgresql+asyncpg://phantom:CHANGE_ME_STRONG_PASSWORD_HERE@db:5432/phantom

# Redis
REDIS_URL=redis://:phantomredis@redis:6379/0
REDIS_PASSWORD=phantomredis

# API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
DEBUG=false

# AI - Claude Mentor (optional)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# AI - Local LLM (Ollama inside docker network)
OLLAMA_URL=http://ollama:11434
LOCAL_MODEL=qwen2.5-coder:3b

# Security Tools
MAX_CONCURRENT_SCANS=2
MAX_REQUESTS_PER_SECOND=5
SCAN_TIMEOUT_MINUTES=120

# VPN / Proxy
VPN_ENABLED=false
PROXY_URL=

# External APIs (optional)
SHODAN_API_KEY=
SECURITYTRAILS_API_KEY=
